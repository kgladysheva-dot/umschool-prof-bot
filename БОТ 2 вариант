                chat.id,
                "Готов(а) ко второму раунду, чтобы узнать свой тип профессии?",
                reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="Гоу! 🚀", callback_data="prof_round2_go")]
                ])
            )
            return

        p1 = pair + 1
        p2 = pair + 26
        title = f"🟦 <b>РАУНД 1</b> • Пара {pair+1}/25"

    else:
        pair = data["pair"]
        if pair >= 12:
            await bot.send_message(
                chat.id,
                "Так волнительно! 😱🥰 Подведем итоги теста?",
                reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="🏁 Итоги теста ПрофКод", callback_data="prof_show_results")]
                ])
            )
            return

        finalists = data["round1_winners"]
        used = set(data["used_in_round2"])
        available = [p for p in finalists if p not in used]

        if len(available) < 2:
            await bot.send_message(
                chat.id,
                "Так волнительно! 😱🥰 Подведем итоги теста?",
                reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="🏁 Итоги теста ПрофКод", callback_data="prof_show_results")]
                ])
            )
            return

        p1, p2 = await get_valid_prof_pair(available)
        data["used_in_round2"].extend([p1, p2])
        title = f"🟪 <b>РАУНД 2</b> • Пара {pair+1}/12"

    text = (
        f"{title}\n\n"
        f"🅰️ <b>{PROF_NAMES[p1]}</b>\n"
