async def pers_render_question(cb: CallbackQuery, state: FSMContext):
    data = await state.get_data()
    index = int(data.get("index", 0))

    if index >= len(PERSONALITY_QUESTIONS):
        scores = data.get("scores", {"G": 0, "I": 0, "R": 0, "A": 0})
        sorted_types = sorted(scores.items(), key=lambda x: x[1], reverse=True)
        main_type = sorted_types[0][0]
        second_type = sorted_types[1][0]

        integral = INTEGRAL_DESC.get((main_type, second_type)) or INTEGRAL_DESC.get((second_type, main_type))

        text = (
            "Ухты! Смотри что рассказал тест про тебя! 😱😱😱\n\n"
            f"✨ <b>Твой ведущий тип личности:</b>\n{TYPE_NAMES.get(main_type, main_type)}\n\n"
            f"{TYPE_LONG_DESC.get(main_type, '')}\n\n"
            f"🌗 <b>Дополнительный (интегральный) тип:</b>\n{TYPE_NAMES.get(second_type, second_type)}\n\n"
        )
        if integral:
            text += integral + "\n\n"
        else:
            text += "Это значит, что у тебя гибкое мышление и широкий потенциал 💪\nТы можешь проявляться по-разному в зависимости от ситуации 🚀\n\n"

        await state.clear()
        await cb.message.edit_text(text, reply_markup=None)
        await cb.message.answer("Меню 👇", reply_markup=TESTS_KEYBOARD)
        await cb.answer()
        return

    q = PERSONALITY_QUESTIONS[index]
    text = f"<b>Вопрос {index + 1}/{len(PERSONALITY_QUESTIONS)}</b>\n\n{q['text']}"
    await cb.message.edit_text(text, reply_markup=pers_kb_answers())
    await cb.answer()

