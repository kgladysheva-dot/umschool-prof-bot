@dp.callback_query(F.data == "pers_start")
async def pers_start(cb: CallbackQuery, state: FSMContext):
    await state.set_state(PersonalityTest.testing)
    await state.update_data(
        index=0,
        scores={"G": 0, "I": 0, "R": 0, "A": 0},
        history=[]
    )
    await pers_render_question(cb, state)

@dp.callback_query(F.data.startswith("pers_ans_"))
async def pers_answer(cb: CallbackQuery, state: FSMContext):
    cur = await state.get_state()
    if cur != PersonalityTest.testing.state:
        await cb.answer("Тест сейчас не запущен 😅", show_alert=True)
        return

    data = await state.get_data()
    index = int(data.get("index", 0))
    scores = data.get("scores", {"G": 0, "I": 0, "R": 0, "A": 0})
    history: List[str] = data.get("history", [])

    if index >= len(PERSONALITY_QUESTIONS):
        await pers_render_question(cb, state)
        return

    answer_letter = cb.data.split("_")[-1]
    q = PERSONALITY_QUESTIONS[index]
    chosen_type = q[answer_letter]

    scores[chosen_type] = scores.get(chosen_type, 0) + 1
    history.append(chosen_type)

    await state.update_data(index=index + 1, scores=scores, history=history)
    await pers_render_question(cb, state)

@dp.callback_query(F.data == "pers_back")
async def pers_back(cb: CallbackQuery, state: FSMContext):
    cur = await state.get_state()
    if cur != PersonalityTest.testing.state:
        await cb.answer("Назад доступно только во время теста", show_alert=True)
        return

    data = await state.get_data()
    index = int(data.get("index", 0))
    scores = data.get("scores", {"G": 0, "I": 0, "R": 0, "A": 0})
    history: List[str] = data.get("history", [])

    if index <= 0 or not history:
        await cb.answer("Это первый вопрос", show_alert=True)
        return

    last_type = history.pop()
    scores[last_type] = max(0, scores.get(last_type, 0) - 1)
    index -= 1

    await state.update_data(index=index, scores=scores, history=history)
    await pers_render_question(cb, state)

