async def prof_results_text(user_id: int) -> str:
    data = prof_users[user_id]
    final = data["round2_winners"]
    total = len(final) if final else 1

    color_count = Counter(COLORS[p] for p in final)
    top3 = color_count.most_common(3)

    text = "🏆 <b>Типы профессий, которые тебе подходят после прохождения теста «ПрофКод»</b>\n\n"
    text += PROFKOD_RESULTS_INTRO

    for i, (color, count) in enumerate(top3, 1):
        info = TYPE_DESCRIPTIONS.get(color)
        if not info:
            continue
        percent = int(round(count / total * 100))
        text += f"{i}️⃣ {info['emoji']} <b>{info['name']}</b> — {percent}%\n"
        text += f"{info['desc']}\n"
        text += f"👉 {info['link']}\n\n"

    return text

