@dp.callback_query(F.data.startswith("talent_pick_"))
async def talent_pick(cb: CallbackQuery):
    user_id = cb.from_user.id
    if user_id not in talent_users:
        await cb.answer("Тест не запущен 😅", show_alert=True)
        return

    tid = int(cb.data.split("_")[-1])
    data = talent_users[user_id]
    r = data["round"]

    if r == 1:
        data["r1_winners"].append(tid)
    elif r == 2:
        data["r2_winners"].append(tid)
    else:
        data["r3_winners"].append(tid)

    await cb.message.delete()
    await show_talent_pair(cb.message.chat, user_id)
    await cb.answer()

@dp.callback_query(F.data == "talent_results")
async def talent_results(cb: CallbackQuery):
    user_id = cb.from_user.id
    if user_id not in talent_users:
        await cb.answer("Тест не запущен 😅", show_alert=True)
        return

    data = talent_users[user_id]
    winners = data["r3_winners"]

    if len(winners) != 5:
        await cb.answer("Похоже, тест ещё не завершён 😅", show_alert=True)
        return

    text = (
        "🌟 <b>Твои ТОП-5 внутриличностных талантов!</b> 🌟\n\n"
        "Ты прошёл(ла) 3 раунда и оставил(а) самые сильные стороны 💪\n\n"
    )

    for i, tid in enumerate(winners, 1):
        text += f"{i}️⃣ <b>{TALENT_NAMES[tid]}</b>\n{TALENT_DESCRIPTIONS[tid]}\n\n"

    text += (
        "🔥 <b>Как использовать это?</b>\n"
        "— Замечай, где эти таланты проявляются в учёбе, общении и решениях\n"
        "— Пробуй роли/задачи, где они включаются чаще\n"
        "— И помни: таланты можно развивать 😉"
    )

    await cb.message.delete()
    await bot.send_message(cb.message.chat.id, text)

    talent_users.pop(user_id, None)
    await cb.answer()

