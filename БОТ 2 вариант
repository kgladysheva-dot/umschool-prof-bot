def mot_kb_start_test() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Начать тест", callback_data="mot_start")],
        [InlineKeyboardButton(text="Отмена", callback_data="mot_cancel")]
    ])

def mot_kb_go() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Поехали", callback_data="mot_go")],
        [InlineKeyboardButton(text="Отмена", callback_data="mot_cancel")]
    ])

def mot_kb_scale() -> InlineKeyboardMarkup:
    row1 = [InlineKeyboardButton(text=str(i), callback_data=f"mot_ans:{i}") for i in range(1, 6)]
    row2 = [
        InlineKeyboardButton(text="⬅️ Назад", callback_data="mot_back"),
        InlineKeyboardButton(text="❌ Отмена", callback_data="mot_cancel"),
    ]
    return InlineKeyboardMarkup(inline_keyboard=[row1, row2])

async def mot_show_question(cb: CallbackQuery, state: FSMContext):
    data = await state.get_data()
    idx = int(data.get("idx", 0))
    answers: List[int] = data.get("answers", [])

    if idx >= len(HERZBERG_QUESTIONS):
        scored: List[Tuple[int, int]] = [(score, i) for i, score in enumerate(answers)]
        scored.sort(key=lambda x: (-x[0], x[1]))
        top3 = scored[:3]

        lines = []
        for rank, (score, qi) in enumerate(top3, start=1):
            q = HERZBERG_QUESTIONS[qi]
            lines.append(f"{rank}) <b>{q.title}</b> — {score}/5")

        result_text = (
            "Твои результаты теста! Это те аспекты, которые тебя мотивируют!)\n\n"
            + "\n".join(lines)
        )

        await state.clear()
        await cb.message.edit_text(result_text, reply_markup=None)
        await cb.message.answer("Меню 👇", reply_markup=TESTS_KEYBOARD)
        await cb.answer()
        return

    q = HERZBERG_QUESTIONS[idx]
    text = (
        f"<b>Утверждение {idx+1} из {len(HERZBERG_QUESTIONS)}</b>\n\n"
        f"{q.text}\n\n"
        "<b>Оцени от 1 до 5</b>"
    )
    await cb.message.edit_text(text, reply_markup=mot_kb_scale())
    await cb.answer()

@dp.message(F.text == "🔥 Тест на мотивацию")
async def mot_entry(message: Message, state: FSMContext):
    await state.set_state(MotivationFlow.intro)
    await state.update_data(idx=0, answers=[])
    await message.answer(MOT_INTRO_TEXT, reply_markup=mot_kb_start_test())

@dp.callback_query(F.data == "mot_cancel")
async def mot_cancel(cb: CallbackQuery, state: FSMContext):
    await state.clear()
    await cb.message.edit_text("Ок, тест отменён ✅", reply_markup=None)
    await cb.message.answer("Меню 👇", reply_markup=TESTS_KEYBOARD)
    await cb.answer()

@dp.callback_query(F.data == "mot_start")
async def mot_start(cb: CallbackQuery, state: FSMContext):
    await state.set_state(MotivationFlow.instructions)
    await cb.message.edit_text(MOT_INSTRUCTIONS_TEXT, reply_markup=mot_kb_go())
    await cb.answer()

@dp.callback_query(F.data == "mot_go")
async def mot_go(cb: CallbackQuery, state: FSMContext):
    await state.set_state(MotivationFlow.in_test)
    data = await state.get_data()
    if "idx" not in data:
        await state.update_data(idx=0, answers=[])
    await mot_show_question(cb, state)

@dp.callback_query(F.data == "mot_back")
async def mot_back(cb: CallbackQuery, state: FSMContext):
    cur = await state.get_state()
    if cur != MotivationFlow.in_test.state:
        await cb.answer("Назад доступно только во время теста", show_alert=True)
        return

    data = await state.get_data()
    idx = int(data.get("idx", 0))
    answers: List[int] = data.get("answers", [])

    if idx == 0:
        await cb.answer("Это первое утверждение", show_alert=True)
        return

    idx -= 1
    if answers:
        answers = answers[:-1]

    await state.update_data(idx=idx, answers=answers)
    await mot_show_question(cb, state)

@dp.callback_query(F.data.startswith("mot_ans:"))
async def mot_answer(cb: CallbackQuery, state: FSMContext):
    cur = await state.get_state()
    if cur != MotivationFlow.in_test.state:
        await cb.answer("Тест сейчас не запущен. Нажми «Тест на мотивацию».", show_alert=True)
        return

    data = await state.get_data()
    idx = int(data.get("idx", 0))
    answers: List[int] = data.get("answers", [])

    try:
        val = int(cb.data.split(":", 1)[1])
        if val < 1 or val > 5:
            raise ValueError
    except Exception:
        await cb.answer("Некорректный ответ", show_alert=True)
        return

    answers.append(val)
    idx += 1

    await state.update_data(idx=idx, answers=answers)
    await mot_show_question(cb, state)

