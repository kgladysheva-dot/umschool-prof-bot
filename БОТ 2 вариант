def kb_know_menu():
    kb = InlineKeyboardBuilder()
    for post_id, data in POSTS.items():
        kb.button(text=data["title"], callback_data=f"know_post:{post_id}")
    kb.button(text="⬅️ Назад в меню", callback_data="know_back:main")
    kb.adjust(1)
    return kb.as_markup()

def kb_post_nav():
    kb = InlineKeyboardBuilder()
    kb.button(text="⬅️ К списку постов", callback_data="know_back:list")
    kb.button(text="🏠 В главное меню", callback_data="know_back:main")
    kb.adjust(1, 1)
    return kb.as_markup()

@know_router.message(F.text == "Хочу знать и понимать")
async def open_know_section_by_text(message: Message):
    await message.answer(MENU_KNOW_TEXT, reply_markup=kb_know_menu())

@know_router.callback_query(F.data.startswith("know_post:"))
async def open_post(call: CallbackQuery):
    post_id = call.data.split(":", 1)[1]
    post = POSTS.get(post_id)

    if post is None:
        await call.answer("Пост не найден 😢", show_alert=True)
        return

    await call.message.edit_text(post["text"], reply_markup=kb_post_nav())
    await call.answer()

@know_router.callback_query(F.data == "know_back:list")
async def back_to_posts_list(call: CallbackQuery):
    await call.message.edit_text(MENU_KNOW_TEXT, reply_markup=kb_know_menu())
    await call.answer()

@know_router.callback_query(F.data == "know_back:main")
async def back_to_main_menu_know(call: CallbackQuery):
    await call.message.answer("Ок! Возвращаю в главное меню ✅", reply_markup=MAIN_KEYBOARD)
    await call.answer()

