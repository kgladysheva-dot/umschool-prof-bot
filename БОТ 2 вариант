def prof_button_title(pid: int) -> str:
    base = PROF_SHORT.get(pid, str(pid))
    return base  # без двойных "№", просто название

async def get_valid_prof_pair(prof_list):
    if len(prof_list) < 2:
        return None, None
    for _ in range(200):
        p1 = random.choice(prof_list)
        candidates = [p for p in prof_list if p != p1 and COLORS[p] != COLORS[p1]]
        if candidates:
            return p1, random.choice(candidates)
    p1 = random.choice(prof_list)
    p2 = random.choice([p for p in prof_list if p != p1])
    return p1, p2

